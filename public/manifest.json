{
  "manifest_version": 3,
  "name": "AetherProxy",
  "version": "1.0.0",
  "description": "Sleek, modern offline proxy manager with rules-based Auto Switch, profiles, and live speed tester.",
  "permissions": [
    "proxy",
    "storage",
    "webRequest",
    "webRequestAuthProvider"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "icons": {
    "16": "favicon.svg",
    "32": "favicon.svg",
    "48": "favicon.svg",
    "128": "favicon.svg"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "AetherProxy Quick Switcher",
    "default_icon": {
      "16": "favicon.svg",
      "32": "favicon.svg",
      "48": "favicon.svg",
      "128": "favicon.svg"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  }
}
