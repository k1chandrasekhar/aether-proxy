{
  "manifest_version": 3,
  "name": "AetherProxy",
  "version": "1.0.0",
  "description": "Sleek, modern offline proxy manager with rules-based Auto Switch, profiles, and live speed tester.",
  "permissions": [
    "proxy",
    "storage",
    "webRequest"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "AetherProxy Quick Switcher"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  }
}
